PORT=3000
USE_LEGACY_DEMO_SERVER=false
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/tintoreria_express?retryWrites=true&w=majority

# Frontend publico para enlaces de verificacion y reset
APP_BASE_URL=https://menta-laundry.vercel.app/

# Dominios permitidos para consumir la API
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://mentalaundry.com,https://www.mentalaundry.com,https://menta-laundry.vercel.app
CORS_ALLOWED_ORIGIN_SUFFIXES=.netlify.app,.onrender.com,.vercel.app

# SMTP / Brevo
EMAIL_FROM=Menta Laundry <admin@mentalaundry.com>
EMAIL_REPLY_TO=admin@mentalaundry.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_brevo_smtp_login
SMTP_PASS=replace_with_brevo_smtp_key
